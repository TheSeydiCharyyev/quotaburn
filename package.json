{
  "name": "ccwhy",
  "version": "0.0.1",
  "description": "ccusage tells you HOW MUCH of your Claude Code quota you burned. ccwhy tells you WHY.",
  "type": "module",
  "bin": {
    "ccwhy": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude",
    "claude-code",
    "tokens",
    "usage",
    "quota",
    "cost",
    "attribution",
    "mcp"
  ],
  "author": "Seydi Charyyev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheSeydiCharyyev/ccwhy.git"
  },
  "homepage": "https://github.com/TheSeydiCharyyev/ccwhy#readme",
  "bugs": {
    "url": "https://github.com/TheSeydiCharyyev/ccwhy/issues"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
