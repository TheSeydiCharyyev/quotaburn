{
  "name": "quotaburn",
  "version": "0.1.0",
  "description": "Find out WHERE your Claude Code quota burns — per-tool attribution, cache expiry bills, repeated reads, MCP dead weight. Local logs only, zero deps.",
  "type": "module",
  "bin": {
    "quotaburn": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "keywords": [
    "claude",
    "claude-code",
    "tokens",
    "usage",
    "quota",
    "cost",
    "attribution",
    "cache",
    "ccusage",
    "mcp"
  ],
  "author": "Seydi Charyyev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheSeydiCharyyev/quotaburn.git"
  },
  "homepage": "https://github.com/TheSeydiCharyyev/quotaburn#readme",
  "bugs": {
    "url": "https://github.com/TheSeydiCharyyev/quotaburn/issues"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
